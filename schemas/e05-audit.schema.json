{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xulei-leon.github.io/particleML/schemas/e05-audit.schema.json",
  "title": "particleML E0.5 audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "e05_audit_id", "status", "formal_gate_eligible",
    "evidence_origin", "dependency_revision", "missing_evidence", "failed_checks",
    "model_condition", "policy_sha256", "content_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "e05_audit_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["passed", "failed", "blocked_external_evidence", "fallback_approved"]},
    "formal_gate_eligible": {"type": "boolean"},
    "evidence_origin": {"type": "string", "minLength": 1},
    "dependency_revision": {"const": "5091595d226b6021e967ab2ecfff832f40c026f6"},
    "missing_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "failed_checks": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "model_condition": {"enum": ["pretrained_omnilearned", "random_initialized_omnilearned"]},
    "policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
