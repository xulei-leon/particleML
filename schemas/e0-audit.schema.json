{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xulei-leon.github.io/particleML/schemas/e0-audit.schema.json",
  "title": "particleML E0 audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "e0_audit_id",
    "evidence_id",
    "status",
    "formal_gate_eligible",
    "missing_evidence",
    "failed_gates",
    "policy_sha256",
    "resource_projection",
    "observed",
    "content_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "e0_audit_id": {"type": "string", "minLength": 1},
    "evidence_id": {"type": "string", "minLength": 1},
    "status": {
      "enum": ["passed", "failed", "blocked_external_evidence"]
    },
    "formal_gate_eligible": {"type": "boolean"},
    "missing_evidence": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "failed_gates": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "resource_projection": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_bytes_per_wall_second",
            "events_per_wall_second",
            "cpu_seconds_per_event",
            "file_failure_fraction",
            "retained_storage_bytes",
            "projected_cost_usd_with_reserve",
            "projected_total_cost_usd_with_reserve"
          ],
          "properties": {
            "source_bytes_per_wall_second": {"type": "number", "minimum": 0},
            "events_per_wall_second": {"type": "number", "minimum": 0},
            "cpu_seconds_per_event": {"type": "number", "minimum": 0},
            "file_failure_fraction": {"type": "number", "minimum": 0, "maximum": 1},
            "retained_storage_bytes": {"type": "integer", "minimum": 0},
            "projected_cost_usd_with_reserve": {
              "type": "object",
              "additionalProperties": false,
              "required": ["E0", "E1", "E2"],
              "properties": {
                "E0": {"type": "number", "minimum": 0},
                "E1": {"type": "number", "minimum": 0},
                "E2": {"type": "number", "minimum": 0}
              }
            },
            "projected_total_cost_usd_with_reserve": {"type": "number", "minimum": 0}
          }
        }
      ]
    },
    "observed": {"type": "object"},
    "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
