{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xulei-leon.github.io/particleML/schemas/prediction.schema.json",
  "title": "particleML Prediction Artifact",
  "description": "Metadata and logical row contract for ordered per-jet predictions stored in an external NPZ, Parquet, or HDF5 payload.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prediction_id",
    "run_id",
    "created_at",
    "partition",
    "feature_config",
    "model_condition",
    "split_manifest_sha256",
    "view_sha256",
    "ordered",
    "row_count",
    "class_counts",
    "row_order_sha256",
    "logical_columns",
    "payload",
    "content_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "prediction_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "created_at": {
      "$ref": "#/$defs/timestamp"
    },
    "partition": {
      "const": "test"
    },
    "feature_config": {
      "enum": ["A", "B", "C", "D"]
    },
    "model_condition": {
      "enum": [
        "pretrained_omnilearned",
        "random_initialized_omnilearned",
        "deep_sets_pfn"
      ]
    },
    "split_manifest_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "view_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "ordered": {
      "const": true
    },
    "row_count": {
      "type": "integer",
      "minimum": 2
    },
    "class_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qcd", "top"],
      "properties": {
        "qcd": { "type": "integer", "minimum": 1 },
        "top": { "type": "integer", "minimum": 1 }
      }
    },
    "row_order_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "logical_columns": {
      "$ref": "#/$defs/logical_columns"
    },
    "payload": {
      "$ref": "#/$defs/payload"
    },
    "content_hash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "canonicalization", "metadata_sha256"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "canonicalization": { "const": "utf8-sorted-keys-compact-json-lf-excluding-content_hash.metadata_sha256" },
        "metadata_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "dtype", "nullable"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "dtype": {
          "enum": ["utf8", "uint16", "uint32", "uint64", "int8", "float32", "float64"]
        },
        "nullable": { "const": false },
        "allowed_values": {
          "type": "array",
          "items": { "type": ["integer", "number", "string"] },
          "minItems": 1,
          "uniqueItems": true
        },
        "range": {
          "type": "array",
          "prefixItems": [
            { "type": "number" },
            { "type": "number" }
          ],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "logical_columns": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jet_id",
        "record_id",
        "run",
        "lumi",
        "event",
        "jet_index",
        "target",
        "signal_score"
      ],
      "properties": {
        "jet_id": {
          "allOf": [
            { "$ref": "#/$defs/column" },
            { "properties": { "name": { "const": "jet_id" }, "dtype": { "const": "utf8" } } }
          ]
        },
        "record_id": {
          "allOf": [
            { "$ref": "#/$defs/column" },
            { "properties": { "name": { "const": "record_id" }, "dtype": { "const": "uint32" } } }
          ]
        },
        "run": {
          "allOf": [
            { "$ref": "#/$defs/column" },
            { "properties": { "name": { "const": "run" }, "dtype": { "const": "uint32" } } }
          ]
        },
        "lumi": {
          "allOf": [
            { "$ref": "#/$defs/column" },
            { "properties": { "name": { "const": "lumi" }, "dtype": { "const": "uint32" } } }
          ]
        },
        "event": {
          "allOf": [
            { "$ref": "#/$defs/column" },
            { "properties": { "name": { "const": "event" }, "dtype": { "const": "uint64" } } }
          ]
        },
        "jet_index": {
          "allOf": [
            { "$ref": "#/$defs/column" },
            { "properties": { "name": { "const": "jet_index" }, "dtype": { "const": "uint16" } } }
          ]
        },
        "target": {
          "allOf": [
            { "$ref": "#/$defs/column" },
            {
              "properties": {
                "name": { "const": "target" },
                "dtype": { "const": "int8" },
                "allowed_values": {
                  "type": "array",
                  "prefixItems": [{ "const": 0 }, { "const": 1 }],
                  "items": false,
                  "minItems": 2,
                  "maxItems": 2
                }
              },
              "required": ["allowed_values"]
            }
          ]
        },
        "signal_score": {
          "allOf": [
            { "$ref": "#/$defs/column" },
            {
              "properties": {
                "name": { "const": "signal_score" },
                "dtype": { "enum": ["float32", "float64"] },
                "range": {
                  "type": "array",
                  "prefixItems": [{ "const": 0 }, { "const": 1 }],
                  "items": false,
                  "minItems": 2,
                  "maxItems": 2
                }
              },
              "required": ["range"]
            }
          ]
        },
        "hard_prediction": {
          "allOf": [
            { "$ref": "#/$defs/column" },
            {
              "properties": {
                "name": { "const": "hard_prediction" },
                "dtype": { "const": "int8" },
                "allowed_values": {
                  "type": "array",
                  "prefixItems": [{ "const": 0 }, { "const": 1 }],
                  "items": false,
                  "minItems": 2,
                  "maxItems": 2
                }
              },
              "required": ["allowed_values"]
            }
          ]
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "path", "sha256", "byte_size", "compression"],
      "properties": {
        "format": { "enum": ["npz", "parquet", "hdf5"] },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "byte_size": { "type": "integer", "minimum": 1 },
        "compression": {
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    }
  }
}
